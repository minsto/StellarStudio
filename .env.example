# =============================================================================
# Stellar Studio — exemple de configuration (.env)
# Copie ce fichier en `.env` et renseigne les valeurs. Ne commite JAMAIS le .env.
# =============================================================================

# --- Launcher (build renderer, optionnel) ------------------------------------
# Flux d'actus dans le launcher. Laisse vide pour desactiver l'onglet actus.
# Peut pointer vers ta fonction Netlify news-feed ou un fichier JSON/Markdown distant.
# VITE_ACTU_STELLAR_JSON_URL=https://ton-site.example/.netlify/functions/news-feed

# Discord Rich Presence (optionnel). ID numerique de TON application Discord.
# STELLAR_DISCORD_CLIENT_ID=

# --- Netlify Functions / Supabase (cote serveur uniquement) ------------------
# A definir dans l'UI Netlify (Site settings > Environment variables), pas ici en prod.
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=          # cle publique (lecture du flux d'actus)
# SUPABASE_SERVICE_ROLE_KEY=  # cle secrete (admin actus) — NE JAMAIS exposer cote client
# NEWS_ADMIN_TOKEN=           # jeton d'acces a la page /admin (actus)
